generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  tagline   String
  avatar    String?
  about     String
  email     String?
  phone     String?
  location  String?
  website   String?
  resume    String?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id        String   @id @default(cuid())
  degree    String
  institute String
  year      String
  detail    String?
  order     Int      @default(0)
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id        String   @id @default(cuid())
  role      String
  company   String
  year      String
  detail    String?
  order     Int      @default(0)
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                String   @id @default(cuid())
  name              String
  description       String
  image             String?
  featuredImage     String?
  cloudinaryPublicId String?
  demoUrl           String?
  githubUrl         String?
  tags              String?
  category          String?
  featured          Boolean  @default(false)
  hidden            Boolean  @default(false)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GalleryImage {
  id                String   @id @default(cuid())
  src               String
  alt               String
  category          String?
  cloudinaryPublicId String?
  hidden            Boolean  @default(false)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  date      String?
  hidden    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quote {
  id        String   @id @default(cuid())
  text      String
  context   String?
  hidden    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id                String   @id @default(cuid())
  title             String
  date              String
  excerpt           String?
  content           String?
  image             String?
  featuredImage     String?
  cloudinaryPublicId String?
  tags              String?
  category          String?
  published         Boolean  @default(false)
  featured          Boolean  @default(false)
  hidden            Boolean  @default(false)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  comments          BlogComment[]
}

model BlogComment {
  id          String   @id @default(cuid())
  blogPostId  String
  name        String
  content     String
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blogPost    BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
}

model StoreProduct {
  id                String   @id @default(cuid())
  name              String
  price             String
  image             String?
  featuredImage     String?
  cloudinaryPublicId String?
  description       String?
  category          String?
  rating            Float?
  buyUrl            String?
  featured          Boolean  @default(false)
  hidden            Boolean  @default(false)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  url       String
  icon      String
  handle    String?
  hidden    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Audio {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  category    String?
  hidden      Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  category    String?
  hidden      Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Code {
  id          String   @id @default(cuid())
  title       String
  content     String
  language    String?
  description String?
  hidden      Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Link {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  category    String?
  hidden      Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GuestbookEntry {
  id        String   @id @default(cuid())
  name      String
  location  String
  email     String?
  phone     String?
  message   String?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WelcomePopup {
  id          String   @id @default(cuid())
  title       String   @default("Welcome!")
  message     String   @default("")
  imageUrl    String?
  buttonText  String?
  buttonUrl   String?
  enabled     Boolean  @default(true)
  showOnce    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LivePodcast {
  id          String   @id @default(cuid())
  title       String   @default("Live Podcast")
  streamUrl   String?
  sourceType  String   @default("custom")
  isActive    Boolean  @default(false)
  status      String   @default("offline")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
